# XDG_CONFIG_HOME points at this repo, so git reads this file instead of
# ~/.config/git/config. Identity is the same everywhere, so it lives here.
# Also pull in the machine-managed config (home-manager on NixOS writes
# there too). Git silently skips missing includes; machine config wins on
# conflicts since the include comes last.
[user]
	name = Tom Ford
	email = tomfordweb@gmail.com

# "ours" merge driver — keep the local side, no conflict. Referenced by
# .gitattributes for beads' .beads/issues.jsonl, which is a machine-generated
# export, NOT the source of truth (that's the Dolt DB, synced over
# refs/dolt/data). Three-way merging a regenerated file only ever produces
# noise, so git is told to stop trying; beads' post-merge hook rewrites the
# export from the database afterwards.
[merge "ours"]
	name = keep our side (for generated files)
	driver = true
