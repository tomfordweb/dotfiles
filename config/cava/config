# GENERATED by bin/rice-build — edit rice/palette.json, not this file.
# cyberdream — ambient desktop visualizer. Runs in a borderless terminal
# pinned to the desktop background (see hyprland.conf cava-bg windowrule).

[general]
mode = normal
framerate = 60
bars = 88
bar_width = 2
bar_spacing = 1
autosens = 1

[input]
method = pulse
source = auto

[output]
method = ncurses
channels = stereo
mono_option = average

# gradient across the cyberdream palette (bottom -> top)
[color]
gradient = 1
gradient_count = 6
gradient_color_1 = '#cba6f7'
gradient_color_2 = '#89b4fa'
gradient_color_3 = '#22d3ee'
gradient_color_4 = '#94e2d5'
gradient_color_5 = '#a6e3a1'
gradient_color_6 = '#ff6ac1'

[smoothing]
noise_reduction = 0.45
