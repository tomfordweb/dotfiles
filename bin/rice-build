#!/usr/bin/env bash
# Render every per-app color config from rice/palette.json (the single
# source of truth). Templates live in rice/templates/*.tmpl and use
# {{name}} placeholders — raw color names, role names (accent-primary…),
# and {{font}}. rice/icons.json (app → icon map) additionally generates
# the waybar workspaces module and the tmux app-icon lookup.
# Generated outputs are committed; never hand-edit them.
#
# Usage: bin/rice-build   (from anywhere; resolves the repo from itself)

set -euo pipefail

REPO="$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)"
PALETTE="$REPO/rice/palette.json"
TEMPLATES="$REPO/rice/templates"

# template -> output (relative to repo root)
declare -A OUTPUTS=(
  [palette.scss.tmpl]="rice/_palette.scss"
  [hypr-colors.tmpl]="config/hypr/colors.conf"
  [tmux-theme.tmpl]="config/tmux/theme.conf"
  [ghostty-colors.tmpl]="config/ghostty/themes/cyberdream"
  [mako.tmpl]="config/mako/config"
  [cava.tmpl]="config/cava/config"
)

# Build one sed script: colors first, then roles resolved to their hex.
SED_SCRIPT="$(jq -r '
  (.colors | to_entries[] | "s/{{\(.key)}}/\(.value)/g"),
  (.roles as $r | .colors as $c | $r | to_entries[] | "s/{{\(.key)}}/\($c[.value])/g"),
  "s/{{font}}/\(.font)/g"
' "$PALETTE")"

for tmpl in "${!OUTPUTS[@]}"; do
  src="$TEMPLATES/$tmpl"
  out="$REPO/${OUTPUTS[$tmpl]}"
  [ -f "$src" ] || { echo "SKIP  $tmpl (template missing)"; continue; }
  mkdir -p "$(dirname "$out")"
  sed "$SED_SCRIPT" "$src" > "$out"
  if grep -qE '\{\{[a-z0-9-]+\}\}' "$out"; then
    echo "ERROR unresolved placeholder in $out:" >&2
    grep -nE '\{\{[a-z0-9-]+\}\}' "$out" >&2
    exit 1
  fi
  echo "BUILD ${OUTPUTS[$tmpl]}"
done

# ---- icon-map outputs (rice/icons.json + palette.json → waybar/tmux) ----
ICONS="$REPO/rice/icons.json"

# waybar: the whole hyprland/workspaces module, pulled in via "include"
# (waybar merges per top-level key, first-defined wins — so the module
# must live ONLY here, not in config.jsonc).
out="$REPO/config/waybar/workspaces.jsonc"
{
  echo "// GENERATED by bin/rice-build — edit rice/icons.json + rice/palette.json, not this file."
  jq --slurpfile p "$PALETTE" '
    $p[0].colors as $c |
    { "hyprland/workspaces": {
        "format": "<span fgcolor=\"#\($c.text)\" font=\"BigBlueTermPlus Nerd Font\">{id} </span>{windows}",
        "format-window-separator": " ",
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        "on-click": "activate",
        "window-rewrite-default": .default,
        "window-rewrite": (.icons
          | map(select(.class or .title)
              | { key: ([(.class // empty | "class<\(.)>"),
                         (.title // empty | "title<\(.)>")] | join(" ")),
                  value: .icon })
          | from_entries)
    } }' "$ICONS"
} > "$out"
echo "BUILD config/waybar/workspaces.jsonc"

# tmux: proc → icon lookup for bin/tmux-window-label
out="$REPO/config/tmux/app-icons.tsv"
{
  echo "# GENERATED by bin/rice-build — edit rice/icons.json, not this file."
  jq -r '.icons[] | select(.proc) | .icon as $i
         | (.proc | if type == "array" then .[] else . end) | "\(.)\t\($i)"' "$ICONS"
} > "$out"
echo "BUILD config/tmux/app-icons.tsv"
