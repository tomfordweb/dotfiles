#!/usr/bin/env bash
# Archive every *.3mf under $HOME to the storage drive, preserving the
# path relative to ~ (e.g. ~/Downloads/benchy.3mf ->
# /mnt/storage/3d/3mf-sync/Downloads/benchy.3mf).
#
# Copy-only: the drive is the archive, so files deleted locally MUST
# survive there — never pass --delete. Idempotent; rsync skips files
# already in sync. Run daily by the sync-3mf systemd timer on minerva
# (nixos/hosts/minerva/default.nix), or by hand anywhere.
set -euo pipefail

DEST="${DEST:-/mnt/storage/3d/3mf-sync}"
STORAGE_MOUNT="/mnt/storage"

if ! mountpoint -q "$STORAGE_MOUNT"; then
  echo "sync-3mf: $STORAGE_MOUNT is not mounted — skipping" >&2
  exit 0
fi

mkdir -p "$DEST"

# Hidden dirs (caches, .local, git objects) are noise. '.?*' not '.*':
# the latter also matches the start dir '.' and prunes the entire tree.
cd "$HOME"
found=$(find . -name '.?*' -prune -o -type f -name '*.3mf' -print | sed 's|^\./||')

if [ -z "$found" ]; then
  echo "sync-3mf: no .3mf files found under $HOME"
  exit 0
fi

printf '%s\n' "$found" | rsync -a --files-from=- "$HOME/" "$DEST/"
echo "sync-3mf: synced $(printf '%s\n' "$found" | wc -l) file(s) to $DEST"
