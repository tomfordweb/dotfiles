#!/usr/bin/env python3
"""Derive Tom's style + preference profiles from the private voice corpus.

Outputs (all inside the private wiki submodule, docs/ai/):
  voice/style-metrics.json      raw measurements
  writing-voice-observed.md     digest + exemplars — what humanizer reads
  preferences-observed.md       working preferences mined from corrections

Register caveat, stated in the digest itself: agent prompts are terse and
imperative on purpose. Structure, rhythm and vocabulary come from here; register
and formality come from the curated writing-voice.md.

  voice-profile                 rebuild from the whole corpus
  voice-profile --incremental   same, cheap enough that it is currently identical
  voice-profile --preferences   only the preference pass
"""
import collections
import json
import os
import re
import statistics
import sys
import urllib.request

HOME = os.path.expanduser("~")
AI_DIR = os.path.join(HOME, "code/tomfordweb/dotfiles/docs/ai")
VOICE_DIR = os.path.join(AI_DIR, "voice")
CORPUS = os.path.join(VOICE_DIR, "corpus.jsonl")
METRICS = os.path.join(VOICE_DIR, "style-metrics.json")
DIGEST = os.path.join(AI_DIR, "writing-voice-observed.md")
PREFS = os.path.join(AI_DIR, "preferences-observed.md")
DENYLIST = os.path.join(AI_DIR, "preferences-denylist.txt")

CORRECTIVE = re.compile(
    r"\b(don'?t|do not|never|always|stop|instead of|i told you|not what i|"
    r"no,|use \w+ not|should (?:have|be)|please (?:don'?t|stop)|"
    r"why did you|you (?:keep|always))\b",
    re.IGNORECASE,
)
STOPWORDS = set("""the a an and or but if then that this these those i you it is are was were be been
to of in on for with as at by from my your our we they he she them us me do does did not no yes so
can could would should will just now here there what when where how why""".split())


def load():
    if not os.path.exists(CORPUS):
        sys.exit("no corpus yet — run voice-corpus first")
    out = []
    for line in open(CORPUS, encoding="utf-8"):
        try:
            out.append(json.loads(line))
        except Exception:
            continue
    return out


def measure(turns):
    sent_lens, word_lens, openers = [], [], collections.Counter()
    tics = collections.Counter()
    punct = collections.Counter()
    lower_i = questions = imperatives = 0

    for t in turns:
        text = t["text"]
        words = re.findall(r"[A-Za-z']+", text)
        word_lens.append(len(words))
        for sent in re.split(r"(?<=[.!?])\s+|\n+", text):
            s = sent.strip()
            if not s:
                continue
            n = len(re.findall(r"[A-Za-z']+", s))
            if n:
                sent_lens.append(n)
                openers[s.split()[0].lower().strip(",.")] += 1
        lower_i += len(re.findall(r"(?<![A-Za-z])i(?![A-Za-z'])", text))
        questions += text.count("?")
        if re.match(r"^\s*(can|could|please|add|fix|make|run|use|write|check|do)\b", text, re.I):
            imperatives += 1
        for ch, name in ((",", "comma"), (";", "semicolon"), ("—", "em_dash"),
                         ("-", "hyphen"), ("(", "paren"), ("'", "apostrophe")):
            punct[name] += text.count(ch)
        for w in words:
            lw = w.lower()
            if lw not in STOPWORDS and len(lw) > 3:
                tics[lw] += 1

    return {
        "turns": len(turns),
        "sentence_words": {
            "median": statistics.median(sent_lens) if sent_lens else 0,
            "mean": round(statistics.mean(sent_lens), 1) if sent_lens else 0,
            "p90": sorted(sent_lens)[int(len(sent_lens) * 0.9)] if sent_lens else 0,
        },
        "turn_words_median": statistics.median(word_lens) if word_lens else 0,
        "top_openers": openers.most_common(15),
        "top_terms": tics.most_common(40),
        "punctuation_per_1k_words": {
            k: round(v / max(sum(word_lens), 1) * 1000, 1) for k, v in punct.items()
        },
        "lowercase_i_count": lower_i,
        "question_rate": round(questions / max(len(turns), 1), 2),
        "imperative_rate": round(imperatives / max(len(turns), 1), 2),
    }


def exemplars(turns, n=20):
    """Highest style signal: long-form turns and corrections, not one-liners."""
    scored = []
    for t in turns:
        words = len(t["text"].split())
        if words < 12:
            continue
        score = words + (60 if CORRECTIVE.search(t["text"]) else 0)
        scored.append((score, t))
    scored.sort(key=lambda x: -x[0])
    return [t for _, t in scored[:n]]


def write_digest(m, ex):
    p = m["punctuation_per_1k_words"]
    lines = [
        "# Tom Ford — observed writing profile (generated)",
        "",
        "Generated by `bin/voice-profile` from `voice/corpus.jsonl` — Tom's own turns across",
        "Claude Code, codex and opencode. Do not hand-edit; edits are overwritten.",
        "",
        "**How to use this file.** Take **sentence structure, rhythm, connective habits and",
        "vocabulary** from here. Take **register and formality from the curated",
        "`writing-voice.md`** — these are agent prompts: terse, imperative, lowercase, typo-",
        "tolerant on purpose. Copying that register into a cover letter or a blog post is the",
        "failure mode this note exists to prevent. Some turns were also written under a",
        "compression mode (caveman), so brevity here is partly an artifact, not pure voice.",
        "",
        f"Corpus: **{m['turns']} turns**.",
        "",
        "## Measured habits",
        "",
        f"- Median sentence: **{m['sentence_words']['median']} words** "
        f"(mean {m['sentence_words']['mean']}, p90 {m['sentence_words']['p90']}) — "
        "short declaratives, occasional long one.",
        f"- Median turn: {m['turn_words_median']} words.",
        f"- Questions per turn: {m['question_rate']}. Imperative openings: {m['imperative_rate']}.",
        f"- Lowercase standalone `i`: {m['lowercase_i_count']} occurrences — a real habit, keep it "
        "in informal contexts, drop it in shipped prose.",
        f"- Punctuation per 1k words: comma {p.get('comma', 0)}, "
        f"em dash {p.get('em_dash', 0)}, semicolon {p.get('semicolon', 0)}, "
        f"paren {p.get('paren', 0)}.",
        "",
        "**Frequent openers:** " + ", ".join(f"`{w}`" for w, _ in m["top_openers"][:10]),
        "",
        "**Recurring vocabulary:** " + ", ".join(f"`{w}`" for w, _ in m["top_terms"][:25]),
        "",
        "## Exemplar turns (few-shot)",
        "",
        "Weighted toward long-form turns and corrections — those carry phrasing preference,",
        "where a one-line command carries none.",
        "",
    ]
    for t in ex:
        text = " ".join(t["text"].split())
        if len(text) > 400:
            text = text[:400] + "…"
        lines.append(f"- {text}")
    lines.append("")
    open(DIGEST, "w", encoding="utf-8").write("\n".join(lines))


def ollama_cluster(samples):
    """Cluster corrections into candidate rules with the LOCAL model. Optional."""
    if not samples:
        return None
    prompt = (
        "Below are corrections a developer gave to AI coding agents. Extract the durable "
        "preferences they imply. Output at most 15 lines, each a single imperative rule in "
        "the developer's own terms, most frequent first. No preamble, no numbering, no "
        "commentary.\n\n" + "\n".join(f"- {s}" for s in samples[:200])
    )
    # HTTP API, not `ollama run`: the CLI renders for a terminal even when piped
    # (spinner escapes, hard line wraps that duplicate partial words) and that
    # junk ends up verbatim in the generated markdown.
    body = json.dumps({
        "model": os.environ.get("VOICE_PROFILE_MODEL", "qwen2.5:14b-instruct-q5_K_M"),
        "prompt": prompt,
        "stream": False,
        "options": {"temperature": 0.2},
    }).encode()
    host = os.environ.get("OLLAMA_HOST", "127.0.0.1:11434")
    try:
        req = urllib.request.Request(
            f"http://{host}/api/generate", data=body,
            headers={"Content-Type": "application/json"},
        )
        with urllib.request.urlopen(req, timeout=300) as resp:
            out = json.load(resp).get("response", "")
        return "\n".join(l.rstrip() for l in out.splitlines() if l.strip()).strip() or None
    except Exception:
        return None


def write_preferences(turns):
    deny = []
    if os.path.exists(DENYLIST):
        deny = [l.strip().lower() for l in open(DENYLIST) if l.strip() and not l.startswith("#")]

    corrections = [t for t in turns if CORRECTIVE.search(t["text"]) and len(t["text"].split()) > 4]
    counter = collections.Counter()
    evidence = collections.defaultdict(list)
    for t in corrections:
        text = " ".join(t["text"].split())
        if any(d in text.lower() for d in deny):
            continue
        key = re.sub(r"[^a-z ]", "", text.lower())
        key = " ".join(w for w in key.split() if w not in STOPWORDS)[:60]
        if not key:
            continue
        counter[key] += 1
        if len(evidence[key]) < 2:
            evidence[key].append(text[:200])

    clustered = ollama_cluster([" ".join(t["text"].split())[:300] for t in corrections])

    lines = [
        "# Observed working preferences (generated)",
        "",
        "Mined by `bin/voice-profile --preferences` from Tom's corrections to agents. Do not",
        "hand-edit — regenerate instead. Rules earn their place by recurring and fall out when",
        "they stop being repeated, so a bad inference cannot become permanent. To suppress one",
        "for good, add a matching substring to `preferences-denylist.txt`.",
        "",
        f"Source: {len(corrections)} corrective turns.",
        "",
    ]
    if clustered:
        lines += ["## Rules (clustered locally by ollama)", "", clustered, ""]
    lines += ["## Most-repeated corrections (raw evidence)", ""]
    for key, n in counter.most_common(15):
        lines.append(f"- **×{n}** — {evidence[key][0]}")
        if len(evidence[key]) > 1:
            lines.append(f"  - also: {evidence[key][1]}")
    lines.append("")
    open(PREFS, "w", encoding="utf-8").write("\n".join(lines))


def main():
    turns = load()
    os.makedirs(VOICE_DIR, exist_ok=True)
    if "--preferences" not in sys.argv:
        m = measure(turns)
        json.dump(m, open(METRICS, "w"), indent=2)
        write_digest(m, exemplars(turns))
    write_preferences(turns)
    print(f"profile: {len(turns)} turns -> {DIGEST}, {PREFS}")


if __name__ == "__main__":
    main()
