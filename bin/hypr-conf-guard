#!/bin/sh
# Restore config/hypr/hyprland.conf when Hyprland clobbers it with its
# autogenerated stub.
#
# Hyprland writes a default stub (marked `autogenerated = 1`) whenever
# it launches and ~/.config/hypr/hyprland.conf doesn't resolve — e.g.
# the brief window while home-manager swaps symlinks during a rebuild.
# Because ~/.config/hypr is a live symlink into this repo, the stub
# lands in the working tree, wiping the real config (and with it every
# `source`/`exec-once` line, so nothing self-heals from inside the
# session). A systemd user path unit (nixos/home/dotfiles.nix) watches
# the file and runs this script, which restores from git and reloads.

set -u

repo="$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd)"
conf="config/hypr/hyprland.conf"

grep -qx 'autogenerated = 1' "$repo/$conf" 2>/dev/null || exit 0

# If HEAD itself somehow held the stub, checkout would loop forever.
git -C "$repo" show "HEAD:$conf" 2>/dev/null | grep -qx 'autogenerated = 1' && exit 0

git -C "$repo" checkout -- "$conf" || exit 1

# hyprctl needs the instance signature; systemd units don't inherit it,
# so fall back to the most recent instance dir.
if [ -z "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]; then
  HYPRLAND_INSTANCE_SIGNATURE="$(ls -t "${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/hypr" 2>/dev/null | head -n 1)"
  export HYPRLAND_INSTANCE_SIGNATURE
fi
if [ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ] && command -v hyprctl >/dev/null 2>&1; then
  hyprctl reload >/dev/null 2>&1 || true
fi
