#!/usr/bin/env python3
"""whisper-ptt-daemon — push-to-talk for whisper dictation on COSMIC.

COSMIC custom shortcuts fire only on key *press*, never release, so they
can't drive hold-to-talk. This daemon reads evdev directly instead: on
key-DOWN it runs `<cmd> start`, on key-UP `<cmd> stop`. Autorepeat (value 2)
is ignored.

Bind your macropad keys to F13 / F14 (non-typing keycodes) in Keychron
Launcher and REMOVE the matching COSMIC custom shortcuts, so the keys have
no other side effects.

  F13 -> whisper-toggle         (record-then-transcribe; hold to talk)
  F14 -> whisper-stream-toggle  (live VAD dictation; hold to talk)

Runs as a systemd --user service (see install/whisper-dictate.sh). Needs
read access to /dev/input/event* => the user must be in the `input` group.

On Hyprland this whole daemon is unnecessary — use `bind`/`bindr` for
down/up directly.
"""
import glob
import os
import select
import subprocess
import sys
import time

try:
    import evdev
    from evdev import ecodes
except ImportError:
    sys.exit("python-evdev not installed (pip install evdev / apt install python3-evdev)")

# keycode -> (command, mode). Commands resolved to absolute paths next to
# this daemon — the systemd --user service PATH does NOT include the repo
# bin/ dir (a bare name would give "command not found").
#
# mode "ptt"    : hold to talk — key-down runs `<cmd> start`, key-up `<cmd> stop`.
# mode "toggle" : tap on / tap off — key-down runs `<cmd> toggle`, key-up ignored.
#   Live streaming uses "toggle": the recognizer needs to stay up (model load
#   + VAD emits on pauses), so a brief hold can't work — you tap it on, talk
#   with natural pauses, then tap off.
_BIN = os.path.dirname(os.path.abspath(__file__))
_PTT = os.path.join(_BIN, "whisper-toggle")
KEYMAP = {
    ecodes.KEY_F13: (_PTT, "ptt"),
    ecodes.KEY_F14: (_PTT, "ptt"),   # both keys = record-then-transcribe push-to-talk
}
# (whisper-stream-toggle / live dictation left in the repo but unbound — the
#  streaming path was noticeably less accurate than record-then-transcribe.)


def find_devices():
    """All readable keyboards. We DON'T filter by KEY_F13/F14 capability —
    QMK boards under-report function keys in their evdev capability set even
    though they emit them. Watch every EV_KEY device we can open; the read
    loop only acts on the keys in KEYMAP, so other keyboards are harmless."""
    # Glob directly rather than evdev.list_devices() — the latter filters by
    # its own access check and silently drops nodes readable only via an ACL
    # (exactly our ACL'd macropad), even though they open fine.
    devs = []
    for path in sorted(glob.glob("/dev/input/event*")):
        try:
            d = evdev.InputDevice(path)
        except (OSError, PermissionError):
            continue
        if ecodes.EV_KEY in d.capabilities():
            devs.append(d)
        else:
            d.close()
    return devs


def run(cmd, action):
    # Fire-and-forget; inherits this service's env (WAYLAND_DISPLAY etc.).
    try:
        subprocess.Popen([cmd, action],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except FileNotFoundError:
        print(f"command not found: {cmd}", file=sys.stderr)


def monitor():
    """Print every key event from all keyboards — for diagnosing what a key
    sends. Run: sudo whisper-ptt-daemon --monitor ; then press the key."""
    devs = []
    for path in evdev.list_devices():
        try:
            d = evdev.InputDevice(path)
            if ecodes.EV_KEY in d.capabilities():
                devs.append(d)
        except (OSError, PermissionError):
            continue
    print(f"monitoring {len(devs)} keyboards — press your key (Ctrl-C to quit)", flush=True)
    fd_map = {d.fd: d for d in devs}
    while True:
        r, _, _ = select.select(fd_map, [], [], None)
        for fd in r:
            for event in fd_map[fd].read():
                if event.type == ecodes.EV_KEY and event.value in (0, 1):
                    name = ecodes.KEY.get(event.code, f"code {event.code}")
                    state = "DOWN" if event.value == 1 else "up  "
                    print(f"  {state}  {name}  ({fd_map[fd].name})", flush=True)


def main():
    if "--monitor" in sys.argv:
        monitor()
        return
    devices = find_devices()
    if not devices:
        # Device may not be plugged in yet; wait and retry rather than dying.
        print("no device with F13/F14 found yet; waiting…", file=sys.stderr)
    print(f"whisper-ptt-daemon watching: {[d.name for d in devices]}", flush=True)

    fd_map = {d.fd: d for d in devices}
    last_scan = time.monotonic()

    while True:
        # Re-scan every 5s to pick up (un)plugged devices.
        if time.monotonic() - last_scan > 5:
            names = {d.path for d in devices}
            fresh = find_devices()
            if {d.path for d in fresh} != names:
                for d in devices:
                    try:
                        d.close()
                    except OSError:
                        pass
                devices = fresh
                fd_map = {d.fd: d for d in devices}
                print(f"rescanned: {[d.name for d in devices]}", flush=True)
            last_scan = time.monotonic()

        if not fd_map:
            time.sleep(1)
            continue

        r, _, _ = select.select(fd_map, [], [], 5)
        for fd in r:
            dev = fd_map.get(fd)
            if dev is None:
                continue
            try:
                for event in dev.read():
                    if event.type != ecodes.EV_KEY or event.code not in KEYMAP:
                        continue
                    cmd, mode = KEYMAP[event.code]
                    if mode == "ptt":
                        if event.value == 1:      # key down -> start
                            run(cmd, "start")
                        elif event.value == 0:    # key up -> stop
                            run(cmd, "stop")
                    elif mode == "toggle":
                        if event.value == 1:      # key down -> toggle; ignore up
                            run(cmd, "toggle")
                    # value == 2 (autorepeat) ignored
            except OSError:
                # Device vanished (unplugged) — drop it; rescan will recover.
                fd_map.pop(fd, None)
                devices = [d for d in devices if d.fd != fd]


if __name__ == "__main__":
    main()
