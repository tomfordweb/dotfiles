# GENERATED by bin/rice-build — edit rice/palette.json, not this file.
# cyberdream — tmux status line + colors (replaces the catppuccin plugin).
# Pill chips are built from nerd-font half-circle glyphs ( / ).

# status bar
set -g status-style "fg=#{{text}},bg=default"
set -g status-position bottom
set -g status-justify left

# left: session chip (cyan)
set -g status-left "#[fg=#{{accent-secondary}},bg=default]#[fg=#{{base}},bg=#{{accent-secondary}},bold]#S#[fg=#{{accent-secondary}},bg=default] "

# windows: glass chips with a darker (mantle2) number cap, current = mauve pill
set -g window-status-separator " "
set -g window-status-format "#[fg=#{{mantle2}},bg=default]#[fg=#{{text}},bg=#{{mantle2}},bold]#I #[fg=#{{overlay0}},bg=#{{surface0}}] #(tmux-window-label '#{pane_pid}' '#{pane_current_command}' '#W' '#{automatic-rename}')#[fg=#{{surface0}},bg=default]"
set -g window-status-current-format "#[fg=#{{mantle2}},bg=default]#[fg=#{{text}},bg=#{{mantle2}},bold]#I #[fg=#{{base}},bg=#{{accent-primary}},bold] #(tmux-window-label '#{pane_pid}' '#{pane_current_command}' '#W' '#{automatic-rename}')#[fg=#{{accent-primary}},bg=default]"
set -g window-status-activity-style "fg=#{{accent-secondary}}"
set -g window-status-bell-style "fg=#{{danger}}"

# right: sysinfo chip (glass, colored icons) + date/time chip (mauve) + host chip (surface)
set -g status-right "#[fg=#{{surface0}},bg=default]#[fg=#{{subtext0}},bg=#{{surface0}}]#(tmux-sysinfo {{green}} {{sky}} {{neon-pink}} {{peach}} {{yellow}} {{subtext0}})#[fg=#{{surface0}},bg=default] #[fg=#{{surface0}},bg=default]#[fg=#{{subtext0}},bg=#{{surface0}}]%a %d %b#[fg=#{{surface0}},bg=default] #[fg=#{{accent-primary}},bg=default]#[fg=#{{base}},bg=#{{accent-primary}},bold]%H:%M#[fg=#{{accent-primary}},bg=default] #[fg=#{{surface0}},bg=default]#[fg=#{{subtext0}},bg=#{{surface0}}]#h#[fg=#{{surface0}},bg=default]"

# panes
set -g pane-border-style "fg=#{{surface0}}"
set -g pane-active-border-style "fg=#{{accent-primary}}"

# messages / prompts
set -g message-style "fg=#{{accent-primary}},bg=#{{base}},bold"
set -g message-command-style "fg=#{{accent-secondary}},bg=#{{base}}"

# copy mode selection + search matches
set -g mode-style "fg=#{{base}},bg=#{{accent-primary}},bold"
set -g copy-mode-match-style "fg=#{{base}},bg=#{{accent-secondary}}"
set -g copy-mode-current-match-style "fg=#{{base}},bg=#{{accent-media}},bold"

# clock (prefix t)
set -g clock-mode-colour "#{{accent-primary}}"
